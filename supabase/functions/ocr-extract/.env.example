# Configuracion del Edge Function ocr-extract
# Estas variables se configuran en Supabase Dashboard > Settings > Edge Functions
# NO se guardan en el repositorio

# Opcional: API Key de Google Vision para OCR mejorado
# Si no se configura, usa Tesseract.js (gratuito, mas lento)
GOOGLE_VISION_API_KEY=

# Las siguientes variables ya estan disponibles automaticamente en el entorno de Edge Functions:
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_DB_URL
